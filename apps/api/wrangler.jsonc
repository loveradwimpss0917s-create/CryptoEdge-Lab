{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cryptoedge-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // docs/01 §4.1: Free plan, 2 Workers total (api + ingest). No Queues, no
  // Workers Paid features. Static Assets serves the web SPA from this same
  // Worker so requests to it don't count against the Free request quota.
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cryptoedge",
      "database_id": "c577a62b-6b1c-4cc7-8912-d98161a0e3ae",
      "migrations_dir": "../../migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CONFIG",
      "id": "c29fc2267e3641178e190b740563e821"
    }
  ],
  "r2_buckets": [
    {
      "binding": "LAKE",
      "bucket_name": "cryptoedge-lake"
    }
  ]
}
